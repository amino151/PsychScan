{
  "name": "Question",
  "type": "object",
  "properties": {
    "text": {
      "type": "string",
      "description": "The question text"
    },
    "type": {
      "type": "string",
      "enum": [
        "multiple_choice",
        "yes_no",
        "scale",
        "situation"
      ],
      "description": "Type of question"
    },
    "category": {
      "type": "string",
      "enum": [
        "introversion_extraversion",
        "analytical_creative",
        "emotional_rational",
        "leadership_collaboration",
        "stress_management"
      ],
      "description": "Psychological dimension this question measures"
    },
    "options": {
      "type": "array",
      "description": "Answer options for multiple choice or situation questions",
      "items": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string"
          },
          "scores": {
            "type": "object",
            "description": "Score weights per profile dimension",
            "properties": {
              "introversion": {
                "type": "number"
              },
              "extraversion": {
                "type": "number"
              },
              "analytical": {
                "type": "number"
              },
              "creative": {
                "type": "number"
              },
              "emotional": {
                "type": "number"
              },
              "rational": {
                "type": "number"
              },
              "leadership": {
                "type": "number"
              },
              "collaboration": {
                "type": "number"
              }
            }
          }
        }
      }
    },
    "order": {
      "type": "number",
      "description": "Display order of the question"
    },
    "is_active": {
      "type": "boolean",
      "default": true,
      "description": "Whether this question is active in the test"
    }
  },
  "required": [
    "text",
    "type",
    "category"
  ]
}