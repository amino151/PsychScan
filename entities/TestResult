{
  "name": "TestResult",
  "type": "object",
  "properties": {
    "user_email": {
      "type": "string",
      "description": "Email of the user who took the test"
    },
    "user_name": {
      "type": "string",
      "description": "Name of the user"
    },
    "scores": {
      "type": "object",
      "description": "Raw scores per dimension",
      "properties": {
        "introversion": {
          "type": "number"
        },
        "extraversion": {
          "type": "number"
        },
        "analytical": {
          "type": "number"
        },
        "creative": {
          "type": "number"
        },
        "emotional": {
          "type": "number"
        },
        "rational": {
          "type": "number"
        },
        "leadership": {
          "type": "number"
        },
        "collaboration": {
          "type": "number"
        }
      }
    },
    "profile_code": {
      "type": "string",
      "description": "Code of the matched psychological profile"
    },
    "profile_name": {
      "type": "string",
      "description": "Name of the matched profile"
    },
    "answers": {
      "type": "array",
      "description": "User's answers",
      "items": {
        "type": "object",
        "properties": {
          "question_id": {
            "type": "string"
          },
          "answer": {
            "type": "string"
          }
        }
      }
    },
    "completion_time_seconds": {
      "type": "number",
      "description": "Time taken to complete the test in seconds"
    },
    "is_guest": {
      "type": "boolean",
      "default": false,
      "description": "Whether this was taken by a guest user"
    }
  },
  "required": [
    "scores",
    "profile_code"
  ]
}